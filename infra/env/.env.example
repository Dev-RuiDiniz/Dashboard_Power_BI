# Ambiente local de desenvolvimento
NODE_ENV=development

# API
API_PORT=3001
PORT=3001

# Web
WEB_PORT=3000
NEXT_PUBLIC_API_URL=http://localhost:3001

# Redis
REDIS_HOST=redis
REDIS_PORT=6379

# SQL Server externo
# Não preencher com dados reais neste arquivo.
# Usar preferencialmente usuário read-only, sem permissões de escrita ou DDL.
SQLSERVER_HOST=
SQLSERVER_PORT=1433
SQLSERVER_DATABASE=
SQLSERVER_USER=
SQLSERVER_PASSWORD=
SQLSERVER_ENCRYPT=true
SQLSERVER_TRUST_SERVER_CERTIFICATE=false
SQLSERVER_CONNECTION_TIMEOUT_MS=5000
SQLSERVER_REQUEST_TIMEOUT_MS=5000
SQLSERVER_POOL_MAX=5
SQLSERVER_POOL_MIN=0
SQLSERVER_POOL_IDLE_TIMEOUT_MS=30000

# Auth
# Use valores fortes e exclusivos por ambiente. Não versionar secrets reais.
AUTH_DEMO_USER_EMAIL=
AUTH_DEMO_USER_PASSWORD=
JWT_ACCESS_SECRET=
JWT_ACCESS_EXPIRES_IN_SECONDS=900
JWT_REFRESH_EXPIRES_IN_SECONDS=604800
BCRYPT_SALT_ROUNDS=10
AUTH_LOGIN_MAX_ATTEMPTS=5
AUTH_LOGIN_WINDOW_SECONDS=900
AUTH_LOGIN_LOCKOUT_SECONDS=900

# Recuperação de senha
PASSWORD_RESET_TOKEN_EXPIRES_SECONDS=900
PASSWORD_RESET_PUBLIC_URL=http://localhost:3000/reset-password
SMTP_MODE=mock
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=
SMTP_SECURE=false
