# Ambiente local de desenvolvimento
NODE_ENV=development

# API
API_PORT=3001
PORT=3001

# Web
WEB_PORT=3000
NEXT_PUBLIC_API_URL=http://localhost:3001

# Redis
REDIS_HOST=redis
REDIS_PORT=6379

# SQL Server externo
# Não preencher com dados reais neste arquivo.
SQLSERVER_HOST=
SQLSERVER_PORT=1433
SQLSERVER_DATABASE=
SQLSERVER_USER=
SQLSERVER_PASSWORD=
SQLSERVER_ENCRYPT=true
SQLSERVER_TRUST_SERVER_CERTIFICATE=false

# Auth
# Use valores fortes e exclusivos por ambiente. Não versionar secrets reais.
AUTH_DEMO_USER_EMAIL=
AUTH_DEMO_USER_PASSWORD=
JWT_ACCESS_SECRET=
JWT_ACCESS_EXPIRES_IN_SECONDS=900
JWT_REFRESH_EXPIRES_IN_SECONDS=604800
BCRYPT_SALT_ROUNDS=10
AUTH_LOGIN_MAX_ATTEMPTS=5
AUTH_LOGIN_WINDOW_SECONDS=900
AUTH_LOGIN_LOCKOUT_SECONDS=900
