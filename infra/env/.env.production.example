API_PORT=3001
WEB_PORT=3000
NGINX_PORT=8082
REDIS_PORT=6379

NODE_ENV=production

NEXT_PUBLIC_API_URL=/api
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

JWT_ACCESS_SECRET=replace-with-a-strong-secret
JWT_ACCESS_EXPIRES_IN_SECONDS=900
JWT_REFRESH_EXPIRES_IN_SECONDS=604800
BCRYPT_SALT_ROUNDS=10
AUTH_LOGIN_MAX_ATTEMPTS=5
AUTH_LOGIN_WINDOW_SECONDS=900
AUTH_LOGIN_LOCKOUT_SECONDS=900

AUTH_DEMO_USER_EMAIL=admin@example.com
AUTH_DEMO_USER_PASSWORD=Admin123!

PASSWORD_RESET_TOKEN_EXPIRES_SECONDS=900
PASSWORD_RESET_PUBLIC_URL=http://YOUR_PUBLIC_URL/reset-password
SMTP_MODE=mock
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=
SMTP_SECURE=false

SQLSERVER_HOST=
SQLSERVER_PORT=1433
SQLSERVER_DATABASE=
SQLSERVER_USER=
SQLSERVER_PASSWORD=
SQLSERVER_ENCRYPT=true
SQLSERVER_TRUST_SERVER_CERTIFICATE=false
SQLSERVER_CONNECTION_TIMEOUT_MS=5000
SQLSERVER_REQUEST_TIMEOUT_MS=5000
SQLSERVER_POOL_MAX=5
SQLSERVER_POOL_MIN=0
SQLSERVER_POOL_IDLE_TIMEOUT_MS=30000
