{
  "name": "dashboard-power-bi",
  "version": "0.1.0",
  "private": true,
  "description": "Monorepo da plataforma web de relatórios e BI Dashboard Power BI.",
  "packageManager": "pnpm@9.15.4",
  "engines": {
    "node": ">=20.11.0",
    "pnpm": ">=9.0.0"
  },
  "scripts": {
    "prepare": "husky",
    "verify:workspace": "node scripts/verify-workspace.mjs",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier . --write",
    "format:check": "prettier . --check",
    "typecheck": "tsc --noEmit -p tsconfig.base.json",
    "quality": "pnpm verify:workspace && pnpm lint && pnpm format:check && pnpm typecheck",
    "build": "pnpm quality",
    "test": "pnpm verify:workspace"
  },
  "lint-staged": {
    "*.{js,mjs,cjs,ts,tsx,json,md,yml,yaml}": [
      "prettier --write"
    ],
    "*.{js,mjs,cjs,ts,tsx}": [
      "eslint --fix"
    ]
  },
  "devDependencies": {
    "@commitlint/cli": "^19.6.1",
    "@commitlint/config-conventional": "^19.6.0",
    "@eslint/js": "^9.17.0",
    "eslint": "^9.17.0",
    "globals": "^15.14.0",
    "husky": "^9.1.7",
    "lint-staged": "^15.2.11",
    "prettier": "^3.4.2",
    "typescript": "^5.7.2",
    "typescript-eslint": "^8.19.0"
  },
  "keywords": [
    "dashboard",
    "power-bi",
    "bi",
    "reports",
    "monorepo"
  ],
  "author": "Rui Diniz",
  "license": "UNLICENSED"
}
